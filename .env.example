# Пример переменных окружения для production.
# Реальный .env создаётся автоматически скриптом scripts/install-panel.sh
# (генерирует случайные секреты). Этот файл — справочник, в git он БЕЗ секретов.
#
# Скопировать и заполнить вручную (только если ставите не через install-panel.sh):
#   cp .env.example .env && chmod 600 .env
# Затем замените все <...> на реальные значения (PANEL_SECRET_KEY и POSTGRES_PASSWORD
# сгенерируйте: openssl rand -hex 32).

APP_NAME=UTMka+AWG
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# --- Секреты (ОБЯЗАТЕЛЬНО задать, без них panel/compose не стартуют) ---
# Пароль БД (одно и то же значение в DATABASE_URL и POSTGRES_PASSWORD):
POSTGRES_PASSWORD=<openssl rand -hex 32>
DATABASE_URL=postgresql+asyncpg://utmka:<POSTGRES_PASSWORD>@postgres:5432/utmka_awg
# Ключ шифрования секретов/JWT/вложений — НЕ менять после установки:
PANEL_SECRET_KEY=<openssl rand -hex 32>

JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# --- Первичный администратор (создаётся при первом запуске) ---
ADMIN_EMAIL=admin@utmka.app
ADMIN_PASSWORD=<задайте надёжный пароль>

# --- Значения по умолчанию для новых серверов ---
DEFAULT_DNS=1.1.1.1
DEFAULT_SUBNET=10.8.1.0/24
DEFAULT_UDP_PORT_MIN=1024
DEFAULT_UDP_PORT_MAX=9999

# --- Пути для самообновления панели (из UI) ---
# Каталог установки на хосте (куда склонирован репозиторий):
PANEL_HOST_DIR=/opt/utmka-awg
PANEL_INSTALL_DIR=/host/utmka-awg
